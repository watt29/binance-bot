# ==================================================
#   BINANCE COMMANDER - .env Template
#   คัดลอกไปเป็น .env แล้วกรอกข้อมูลจริง
# ==================================================

# --- BINANCE GLOBAL FUTURES API (Required) ---
GL_API_KEY=put_your_binance_global_api_key_here
GL_API_SECRET=put_your_binance_global_api_secret_here

# --- TELEGRAM BOT (Required) ---
TELEGRAM_TOKEN=put_your_telegram_bot_token_here
TELEGRAM_CHAT_ID=put_your_personal_chat_id_here

# --- LOCAL MODE (Optional) ---
# เว้นว่าง = รันแบบ Local Telegram Polling (คอมบ้าน)
# ถ้ามี public URL ให้ใส่ (ไม่ต้องมี https://)
# EXTERNAL_URL=yourdomain.duckdns.org

# --- PROXY (Optional) ---
# BINANCE_PROXY=http://your_proxy:port
